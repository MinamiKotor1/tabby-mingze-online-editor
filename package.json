{
  "name": "tabby-mingze-online-editor",
  "version": "0.1.0",
  "description": "Edit remote files over SFTP inside Tabby using Monaco.",
  "keywords": [
    "tabby-plugin"
  ],
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "webpack --progress --color --mode development",
    "build:prod": "webpack --progress --color --mode production",
    "watch": "webpack --progress --color --watch --mode development",
    "prepublishOnly": "yarn build"
  },
  "files": [
    "dist"
  ],
  "author": "Mingze",
  "license": "MIT",
  "dependencies": {
    "github-markdown-css": "^5.9.0",
    "katex": "^0.16.45",
    "monaco-editor": "^0.47.0",
    "pdfjs-dist": "3.11.174",
    "rehype-katex": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/webpack-env": "^1.16.0",
    "apply-loader": "^2.0.0",
    "css-loader": "^6.10.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "pug": "^3.0.2",
    "pug-loader": "^2.4.0",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1"
  },
  "peerDependencies": {
    "@angular/common": "*",
    "@angular/core": "*",
    "rxjs": "*",
    "tabby-core": "*",
    "tabby-ssh": "*"
  }
